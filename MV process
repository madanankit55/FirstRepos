-- Silver: Clean orders (enforce DQ) & enrich with product category
CREATE OR REPLACE MATERIALIZED LAKE VIEW silver.orders_clean_enriched
(
  CONSTRAINT chk_amount_positive CHECK (amount > 0) ON MISMATCH DROP,
  CONSTRAINT chk_valid_date      CHECK (order_date IS NOT NULL) ON MISMATCH FAIL
)
PARTITIONED BY (order_date)
COMMENT "Cleaned orders with product attributes for analytics"
AS
WITH valid_orders AS (
  SELECT
      o.order_id,
      o.customer_id,
      CAST(o.order_ts AS DATE) AS order_date,
      o.product_id,
      CAST(o.quantity AS INT)   AS qty,
      CAST(o.unit_price AS DECIMAL(18,2)) AS unit_price,
      (CAST(o.quantity AS INT) * CAST(o.unit_price AS DECIMAL(18,2))) AS amount
  FROM bronze.orders o
  -- keep only deterministic expressions to preserve incremental eligibility
  WHERE o.order_ts IS NOT NULL
),
products_dedup AS (
  SELECT
      p.product_id,
      p.product_name,
      p.category,
      p.current_price
  FROM bronze.products p
  -- assume upstream has deduped; if not, add a deterministic row_number filter
)
SELECT
  v.order_id,
  v.customer_id,
  v.order_date,
  v.product_id,
  d.product_name,
  d.category,
  v.qty,
  v.unit_price,
  v.amount
FROM valid_orders v
INNER JOIN products_dedup d
  ON v.product_id = d.product_id;


