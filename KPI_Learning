            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDORPARTYTYPE = 1                  THEN 'COMPLETENESS_KPI_INVALID_VENDORPARTYTYPE | '                  ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_ICO_DIMENSION = 1                    THEN 'COMPLETENESS_KPI_INVALID_ICO_DIMENSION | '                    ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_LANGUAGEID = 1                       THEN 'COMPLETENESS_KPI_INVALID_LANGUAGEID | '                       ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_MISMATCH_IN_ORG_NAMES = 1            THEN 'COMPLETENESS_KPI_INVALID_MISMATCH_IN_ORG_NAMES | '            ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDORORGANIZATIONNAME = 1           THEN 'COMPLETENESS_KPI_INVALID_VENDORORGANIZATIONNAME | '           ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYMODEID = 1            THEN 'COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYMODEID | '            ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYTERMSCODE = 1         THEN 'COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYTERMSCODE | '         ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_INVOICEVENDORACCOUNTNUMBER = 1       THEN 'COMPLETENESS_KPI_INVALID_INVOICEVENDORACCOUNTNUMBER | '       ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_DEFAULTPAYMENTTERMSNAME = 1          THEN 'COMPLETENESS_KPI_INVALID_DEFAULTPAYMENTTERMSNAME | '          ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_DEFAULTVENDORPAYMENTMETHODNAME = 1   THEN 'COMPLETENESS_KPI_INVALID_DEFAULTVENDORPAYMENTMETHODNAME | '   ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_VAT_GROUP_CODE_COUNTRY = 1           THEN 'COMPLETENESS_KPI_INVALID_VAT_GROUP_CODE_COUNTRY | '           ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_SALES_TAX_COUNTRY = 1                THEN 'COMPLETENESS_KPI_INVALID_SALES_TAX_COUNTRY | '                ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_SALESTAXGROUPCODE = 1                THEN 'COMPLETENESS_KPI_INVALID_SALESTAXGROUPCODE | '                ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_CURRENCYCODE = 1                     THEN 'COMPLETENESS_KPI_INVALID_CURRENCYCODE | '                     ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_PURCHASESHIPCALENDARID = 1                   THEN 'COMPLETENESS_KPI_PURCHASESHIPCALENDARID | '                   ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_STIBOVENDSTATUS = 1                  THEN 'COMPLETENESS_KPI_INVALID_STIBOVENDSTATUS | '                  ELSE '' END
