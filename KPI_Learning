-- Vendor Account Type
, VENDDOR_ACCOUNT_TYPE AS (
    SELECT 
        CAST(SUVC AS NVARCHAR) AS VENDORACCOUNTNUMBER
        , 'INVOICE' AS VENDDOR_ACCOUNT_TYPE
    FROM 
        STG_EKF_STIBO.VENDOR_INVOICE
    
    UNION

    SELECT 
        SUVC_ORDERING_SHIPPING AS VENDORACCOUNTNUMBER
        , 'ORDER_SHIPPING' AS VENDDOR_ACCOUNT_TYPE
    FROM 
        STG_EKF_STIBO.VENDOR_ORDER_SHIPPING
    WHERE 
        -- Filter Order Shippling acconts which have the same account number as invoice
        -- These will setup in D365 as a single Invoice account in D365 with multiple invoice and delivery addresses
        SUVC_ORDERING_SHIPPING NOT IN (SELECT CAST(SUVC AS NVARCHAR) FROM STG_EKF_STIBO.VENDOR_INVOICE)
)
