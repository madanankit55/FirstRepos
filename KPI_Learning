            , CASE WHEN COMPLETENESS_KPI_INVALID_NO_DELIVERY_ADDRESS = 1              THEN 'COMPLETENESS_KPI_INVALID_NO_DELIVERY_ADDRESS | '              ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_INDIRECT_VENDOR = 1                  THEN 'COMPLETENESS_KPI_INVALID_INDIRECT_VENDOR | '                  ELSE '' END  
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_DESCRIPTION = 1       THEN 'COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_DESCRIPTION | '       ELSE '' END          
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_ISPRIMARY = 1         THEN 'COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_ISPRIMARY | '         ELSE '' END                       
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDORACCOUNTNUMBER = 1              THEN 'COMPLETENESS_KPI_INVALID_VENDORACCOUNTNUMBER | '              ELSE '' END      
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDORGROUPID = 1                    THEN 'COMPLETENESS_KPI_INVALID_VENDORGROUPID | '                    ELSE '' END
            , CASE WHEN COMPLETENESS_KPI_INVALID_VENDORSEARCHNAME = 1                 THEN 'COMPLETENESS_KPI_INVALID_VENDORSEARCHNAME | '                 ELSE '' END  
            , CASE WHEN COMPLETENESS_KPI_INVALID_ORG_NUMBER_MISMATCH_ORG_NAME = 1     THEN 'COMPLETENESS_KPI_INVALID_ORG_NUMBER_MISMATCH_ORG_NAME | '     ELSE '' END
        )) AS VALIDATION_FAILURES_LIST

        -- Get rest of the columns
