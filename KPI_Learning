-- DV_VENDORS
, DV_VENDORS AS (
    SELECT
        tv2.VENDORACCOUNTNUMBER
        , tv2.VENDDOR_ACCOUNT_TYPE
        , tv2.VENDORGROUPID

        -- Invalid if VENDORGROUPID is INDIRECT and there are no Order Shipping Vendor associated with it
        , CASE
            WHEN 
                tv2.VENDORGROUPID = 'INDIRECT' 
                -- Check for Invoice Vendors only
                AND tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE'
                
                AND (SELECT COUNT(*) FROM TRN_VENDORS_V2 AS tv21 WHERE 
                -- Filter only Order Shipping Vendors
                tv21.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'
                and tv21.INVOICEVENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER) > 0 
            THEN 1
            ELSE 0
        END AS PURCHASE_CONTROL_KPI_INVALID_INDIRECT_OS_VENDOR

        -- Invalid if VENDORGROUPID is TRADE and there are NO Order Shipping Vendor associated with it
        , CASE 
            WHEN 
                tv2.VENDORGROUPID in ('TRADE', 'ICO')
                -- Check for Invoice Vendors only
                AND tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE'
                
                AND (SELECT COUNT(*) FROM TRN_VENDORS_V2 AS tv21 WHERE
                -- Filter only Order Shipping Vendors
                tv21.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'
                and tv21.INVOICEVENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER) = 0 
            THEN 1
            ELSE 0 
        END AS PURCHASE_CONTROL_KPI_INVALID_TRADE_OS_VENDOR

        , tv2.VENDORPARTYTYPE
        -- Invalid if VENDORPARTYTYPE is not populated
        , CASE 
            WHEN tv2.VENDORPARTYTYPE IS NULL OR LTRIM(RTRIM(tv2.VENDORPARTYTYPE)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDORPARTYTYPE

        , tv2.DEFAULTLEDGERDIMENSIONDISPLAYVALUE
        -- Invalid if VENDORGROUPID is ICO and the DEFAULTLEDGERDIMENSIONDISPLAYVALUE is not populated
        , CASE 
            WHEN tv2.VENDORGROUPID = 'ICO' 
            AND (tv2.DEFAULTLEDGERDIMENSIONDISPLAYVALUE IS NULL 
            OR LTRIM(RTRIM(tv2.DEFAULTLEDGERDIMENSIONDISPLAYVALUE)) = '' 
            OR LTRIM(RTRIM(tv2.DEFAULTLEDGERDIMENSIONDISPLAYVALUE)) = '--------') THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_ICO_DIMENSION

        , tv2.LANGUAGEID
        -- Invalid if LANGUAGEID is not populated
        , CASE 
            WHEN tv2.LANGUAGEID IS NULL OR LTRIM(RTRIM(tv2.LANGUAGEID)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_LANGUAGEID

        , tv2.ORGANIZATIONNUMBER
        , tv2.VENDORORGANIZATIONNAME
        -- Invalid if Invoice and Order Shipping Account is the same and VENDORORGANIZATIONNAME is different between them
        , CASE 
            WHEN 
            -- Check for a given Invoice Vendors all its assoicated Order Shipping account
            tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE' 

            AND (SELECT COUNT(*) FROM TRN_VENDORS_V2 AS tv21 WHERE
            -- Filter only Order Shipping Vendors
            tv21.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'

            -- Check if the Order Shipping vendors with the same account number have different VENDORORGANIZATIONNAME
            -- Setting the collation to be case sensitive (SQL_Latin1_General_CP1_CS_AS) instead of the default (SQL_Latin1_General_CP1_CI_AS)
            AND tv21.VENDORACCOUNTNUMBER = tv2.INVOICEVENDORACCOUNTNUMBER
            AND tv21.VENDORORGANIZATIONNAME COLLATE SQL_Latin1_General_CP1_CS_AS != tv2.VENDORORGANIZATIONNAME COLLATE SQL_Latin1_General_CP1_CS_AS) <> 0 THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_MISMATCH_IN_ORG_NAMES
    
        -- Invalid if VENDORORGANIZATIONNAME is not populated
        , CASE 
            WHEN tv2.VENDORORGANIZATIONNAME IS NULL OR LTRIM(RTRIM(tv2.VENDORORGANIZATIONNAME)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDORORGANIZATIONNAME

        , tv2.BUYERGROUPID
        , tv2.DEFAULTDELIVERYMODEID
        -- Invalid if DEFAULTDELIVERYMODEID is not populated for Order Shipping Vendor
        , CASE 
            -- For Order Shipping Vendor 
            WHEN tv2.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'
            
            -- Check if the order shipping vendor has a delivery address 
            AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
                WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER and tvpa.ADDRESSLOCATIONROLES = 'Delivery') > 0
            
            AND (tv2.DEFAULTDELIVERYMODEID IS NULL OR LTRIM(RTRIM(tv2.DEFAULTDELIVERYMODEID)) = '') THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYMODEID

        , tv2.DEFAULTDELIVERYTERMSCODE
        -- Invalid if DEFAULTDELIVERYTERMSCODE is not populated for Order Shipping Vendor
        , CASE 
            -- For Order Shipping Vendor 
            WHEN tv2.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING' 

            -- Check if the order shipping vendor has a delivery address 
            AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER and tvpa.ADDRESSLOCATIONROLES = 'Delivery') > 0

            AND (tv2.DEFAULTDELIVERYTERMSCODE IS NULL OR LTRIM(RTRIM(tv2.DEFAULTDELIVERYTERMSCODE)) = '') THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_DEFAULTDELIVERYTERMSCODE

        , tv2.INVOICEVENDORACCOUNTNUMBER
        -- Invalid if INVOICEVENDORACCOUNTNUMBER is not populated
        , CASE 
            WHEN (tv2.INVOICEVENDORACCOUNTNUMBER IS NULL OR LTRIM(RTRIM(tv2.INVOICEVENDORACCOUNTNUMBER)) = '') THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_INVOICEVENDORACCOUNTNUMBER

        , tv2.DEFAULTPAYMENTTERMSNAME
        -- Invalid if DEFAULTPAYMENTTERMSNAME is not populated
        , CASE 
            WHEN tv2.DEFAULTPAYMENTTERMSNAME IS NULL OR LTRIM(RTRIM(tv2.DEFAULTPAYMENTTERMSNAME)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_DEFAULTPAYMENTTERMSNAME

        , tv2.DEFAULTVENDORPAYMENTMETHODNAME
        -- Invalid if DEFAULTVENDORPAYMENTMETHODNAME is not populated
        , CASE 
            WHEN tv2.DEFAULTVENDORPAYMENTMETHODNAME IS NULL OR LTRIM(RTRIM(tv2.DEFAULTVENDORPAYMENTMETHODNAME)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_DEFAULTVENDORPAYMENTMETHODNAME

        , tv2.TAXEXEMPTNUMBER
        , LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2) AS VAT_COUNTRY_PREFIX
        , tv2.SALESTAXGROUPCODE

        -- Invalid when TAXEXEMPTNUMBER country prefix does not align with SALESTAXGROUPCODE configuration
        -- For prefix of SE in TAXEXEMPTNUMBER, the SALESTAXGROUPCODE should be S-DOM
        -- For prefix of EU country code in TAXEXEMPTNUMBER, the SALESTAXGROUPCODE should be S-EU
        -- For prefix of Non EU country code in TAXEXEMPTNUMBER, the SALESTAXGROUPCODE should be S-INT
        -- Check only for Invoice vendors
        , CASE 
            -- For Invoice Vendors
            WHEN tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE' THEN
            CASE 
                
                WHEN 
                    LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2) = 'SE' 
                    AND (tv2.SALESTAXGROUPCODE <> 'S-DOM' 
                        -- Validate if the address is also SE
                        OR (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
                            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
                            AND tvpa.ADDRESSCOUNTRYREGIONISOCODE = 'SE'
                            ) = 0 
                    ) 
                THEN 1
                
                WHEN LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2) IN (SELECT COUNTRY_CODE FROM EU_EEA_EFTA) 
                AND (tv2.SALESTAXGROUPCODE <> 'S-EU' 
                    -- Validate if the address country matches VAT registration country
                    OR (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
                            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
                            AND tvpa.ADDRESSCOUNTRYREGIONISOCODE = LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2)
                            ) = 0
                ) THEN 1
                
                WHEN LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2) NOT IN (SELECT COUNTRY_CODE FROM EU_EEA_EFTA) AND LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2) <> 'SE' 
                AND (tv2.SALESTAXGROUPCODE <> 'S-INT' 
                    -- Validate if the address country matches VAT registration country
                    OR (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
                            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
                            AND tvpa.ADDRESSCOUNTRYREGIONISOCODE = LEFT(LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)), 2)
                            ) = 0                
                ) THEN 1
                
                WHEN tv2.TAXEXEMPTNUMBER IS NULL OR LTRIM(RTRIM(tv2.TAXEXEMPTNUMBER)) = '' OR tv2.SALESTAXGROUPCODE IS NULL OR LTRIM(RTRIM(tv2.SALESTAXGROUPCODE)) = '' THEN 1
                ELSE 0
            END
            ELSE 0 
        END AS COMPLETENESS_KPI_INVALID_VAT_GROUP_CODE_COUNTRY

        , (SELECT LEFT(tvstn.VATNUM, 2) FROM TRN_VENDOR_SALES_TAX_NUMBER tvstn
            WHERE tvstn.VATNUM = tv2.TAXEXEMPTNUMBER
        ) AS VATNUM_COUNTRY_PREFIX

        -- Invalid when the SALES TAX EXEMPTNUMBER COUNTRYREGIONID does not align with prefix of VATNUM
        , CASE 
            WHEN VENDDOR_ACCOUNT_TYPE = 'INVOICE'
            AND (SELECT CASE WHEN LEFT(tvstn.VATNUM, 2) = COUNTRYISOCODE THEN 0 ELSE 1 END 
                FROM TRN_VENDOR_SALES_TAX_NUMBER tvstn
                WHERE tvstn.VATNUM = tv2.TAXEXEMPTNUMBER) = 1
            THEN 1 ELSE 0
        END AS COMPLETENESS_KPI_INVALID_SALES_TAX_COUNTRY

        -- Invalid if SALESTAXGROUPCODE is not populated for a vendor
        , CASE 
            WHEN tv2.SALESTAXGROUPCODE IS NULL OR LTRIM(RTRIM(tv2.SALESTAXGROUPCODE)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_SALESTAXGROUPCODE

        , tv2.CURRENCYCODE
        -- Invalid if CURRENCYCODE is not populated
        , CASE 
            WHEN tv2.CURRENCYCODE IS NULL OR LTRIM(RTRIM(tv2.CURRENCYCODE)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_CURRENCYCODE

        , tv2.PURCHASESHIPCALENDARID
        -- Invalid if PURCHASESHIPCALENDARID is not populated for Order Shipping Vendor
        , CASE 
            -- For Order Shipping Vendor 
            WHEN tv2.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING' 
            AND (tv2.PURCHASESHIPCALENDARID IS NULL OR LTRIM(RTRIM(tv2.PURCHASESHIPCALENDARID)) = '') 
            
            -- Check if there is a delivery address associated with the account
            AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa 
                WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER and tvpa.ADDRESSLOCATIONROLES = 'Delivery') > 0
            THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_PURCHASESHIPCALENDARID

        , tv2.STIBOVENDSTATUS
        -- Invalid if STIBOVENDSTATUS is not populated
        , CASE 
            WHEN tv2.STIBOVENDSTATUS IS NULL OR LTRIM(RTRIM(tv2.STIBOVENDSTATUS)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_STIBOVENDSTATUS

        -- String Aggregated multiple vendor addresses rows into one row separated by semicolon
        , ( SELECT STRING_AGG(tvpa.ADDRESSSTREET, '| ') WITHIN GROUP (ORDER BY tvpa.ADDRESSSTREET)
            FROM TRN_VENDOR_POSTAL_ADDRESS tvpa
            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
        ) AS VENDOR_ADDRESSES
        
        , ( SELECT STRING_AGG(tvpa.ADDRESSLOCATIONROLES, '| ') WITHIN GROUP (ORDER BY tvpa.ADDRESSLOCATIONROLES)
            FROM TRN_VENDOR_POSTAL_ADDRESS tvpa
            WHERE tvpa.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
        ) AS VENDOR_ADDRESS_ROLES
        
        -- Invalid if every vendor DOES NOT have atleast 1 address
        , CASE 
            WHEN 
                (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa WHERE tvpa.VENDORACCOUNTNUMBER  = tv2.VENDORACCOUNTNUMBER) = 0
            THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_NO_VENDOR_ADDRESS

        -- Invalid if the Vendor is a TRADE or ICO vendor and there is no delivery address associated with the vendor account
        -- For Invoice Account - validate if the child Order shipping account has a delivery address.
        , CASE 
            WHEN VENDORGROUPID in ('TRADE', 'ICO')
                AND tv2.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'
                AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa WHERE 
                    tvpa.VENDORACCOUNTNUMBER  = tv2.VENDORACCOUNTNUMBER
                    AND tvpa.ADDRESSLOCATIONROLES = 'Delivery' ) = 0
            THEN 1

            WHEN VENDORGROUPID in ('TRADE', 'ICO')
                AND tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE'
                AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa WHERE 
                    tvpa.VENDORACCOUNTNUMBER IN 
                    (SELECT VENDORACCOUNTNUMBER FROM TRN_VENDORS_V2 tv21 WHERE 
                    tv21.INVOICEVENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER)
                    AND tvpa.ADDRESSLOCATIONROLES = 'Delivery') = 0
            THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_NO_DELIVERY_ADDRESS

        -- Invalid if the vendor is INDIRECT and there is a delivery address associated with it. 
        -- For Invoice Account - Invalid when there are Child Order Shipping accounts
        , CASE 
            WHEN VENDORGROUPID = 'INDIRECT'
            AND tv2.VENDDOR_ACCOUNT_TYPE = 'INVOICE'
            AND (SELECT COUNT(*) FROM TRN_VENDOR_POSTAL_ADDRESS tvpa WHERE 
                    tvpa.VENDORACCOUNTNUMBER  = tv2.VENDORACCOUNTNUMBER
                    AND tvpa.ADDRESSLOCATIONROLES = 'Delivery' ) <> 0
            THEN 1

            WHEN VENDORGROUPID = 'INDIRECT'
            AND tv2.VENDDOR_ACCOUNT_TYPE = 'ORDER_SHIPPING'
            THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_INDIRECT_VENDOR

        -- String Agg multiple Vendor Contact information separated by pipe
        , ( SELECT STRING_AGG(tvci.LOCATOR, ' | ') WITHIN GROUP (ORDER BY tvci.LOCATOR)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
            AND tvci.TYPE = 'Email Address' 
        ) AS VENDOR_CONTACT_EMAILS

        -- String Agg multiple Vendor Contact information separated by pipe
        , ( SELECT STRING_AGG(tvci.PURPOSE, ' | ') WITHIN GROUP (ORDER BY tvci.LOCATOR)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
            AND tvci.TYPE = 'Email Address' 
        ) AS VENDOR_CONTACT_EMAIL_PURPOSE

        -- String Agg multiple Vendor Contact information separated by pipe
        , ( SELECT STRING_AGG(tvci.LOCATOR, ' | ') WITHIN GROUP (ORDER BY tvci.LOCATOR)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
            AND tvci.TYPE = 'Phone' 
        ) AS VENDOR_CONTACT_PHONES

        -- String Agg multiple Vendor Contact information separated by pipe
        , ( SELECT STRING_AGG(tvci.PURPOSE, ' | ') WITHIN GROUP (ORDER BY tvci.LOCATOR)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
            AND tvci.TYPE = 'Phone' 
        ) AS VENDOR_CONTACT_PHONES_PURPOSE

        -- Invalid if the Vendor does not have a Contact email with Purpose
        -- TODO: Need to update based on KPI requirements

        , ( SELECT STRING_AGG(tvci.DESCRIPTION, ' | ') WITHIN GROUP (ORDER BY tvci.DESCRIPTION)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
        ) AS VENDOR_CONTACT_DESCRIPTION

        -- Invalid when the description is NULL
        , CASE
            WHEN ( SELECT STRING_AGG(tvci.DESCRIPTION, ' | ') WITHIN GROUP (ORDER BY tvci.DESCRIPTION)
            FROM TRN_VENDOR_CONTACT tvci
            WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER) IS NULL THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_DESCRIPTION

        -- Invalid when Vendor Contact IS PRIMARY is not marked as 1 for each vendor and contact type
        , CASE 
            WHEN (SELECT 
                    CASE 
                        WHEN COUNT (DISTINCT TYPE) <> SUM(CASE WHEN ISPRIMARY='Yes' THEN 1 ELSE 0 END) 
                        THEN 1 
                        ELSE 0 
                    END AS MISSING_PRIMARY
                FROM TRN_VENDOR_CONTACT tvci
                WHERE tvci.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER
            ) = 1 THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDOR_CONTACT_ISPRIMARY

        -- Invalid if a Vendor does not have atleast 1 bank account
        , CASE 
            WHEN (SELECT COUNT(*) FROM TRN_VENDOR_BANK_ACCOUNT tvba WHERE tvba.VENDORACCOUNTNUMBER = tv2.VENDORACCOUNTNUMBER) = 0 THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_NO_BANK_ACCOUNT

        -- Invalid if VENDORACCOUNTNUMBER is NOT populated
        , CASE 
            WHEN tv2.VENDORACCOUNTNUMBER IS NULL OR LTRIM(RTRIM(tv2.VENDORACCOUNTNUMBER)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDORACCOUNTNUMBER

        -- Invalid if VENDORGROUPID is NOT populated
        , CASE 
            WHEN tv2.VENDORGROUPID IS NULL OR LTRIM(RTRIM(tv2.VENDORGROUPID)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDORGROUPID

        -- Invalid if VENDORSEARCHNAME is NOT populated
        , CASE 
            WHEN tv2.VENDORSEARCHNAME IS NULL OR LTRIM(RTRIM(tv2.VENDORSEARCHNAME)) = '' THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_VENDORSEARCHNAME

        -- Invalide when the ORGANIZATIONNUMBER is same but VENDORORGANIZATIONNAME is different
        , CASE 
            WHEN tv2.ORGANIZATIONNUMBER IS NOT NULL AND LTRIM(RTRIM(tv2.ORGANIZATIONNUMBER)) <> '' 
            AND (SELECT COUNT(DISTINCT VENDORORGANIZATIONNAME) FROM TRN_VENDORS_V2 tv21 
                WHERE tv21.ORGANIZATIONNUMBER = tv2.ORGANIZATIONNUMBER) > 1 THEN 1
            ELSE 0
        END AS COMPLETENESS_KPI_INVALID_ORG_NUMBER_MISMATCH_ORG_NAME

    FROM 
        TRN_VENDORS_V2 tv2
)
